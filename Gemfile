source "https://rubygems.org"

gem "sinatra"                   # Web Framework
gem "sinatra-contrib"           # Sinatra extensions
gem "activerecord"              # Object-Relational Mapping (ORM)
gem "sinatra-activerecord"      # ActiveRecord integration with Sinatra
gem "sqlite3"                   # Database Driver (SQLite)
gem "rerun"                     # Auto reload when files change
gem "dotenv"                    # Load env vars from .env file
gem "httparty"                  # HTTP client
gem "rackup"                    # Sinatra server
gem "puma"                      # Server
gem "rake"                      # Task runner for migrations
